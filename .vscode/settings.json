{
    // 文件编码设置
    "files.encoding": "gb2312",
    "files.autoGuessEncoding": true,

    // C/C++ 文件特定编码
    "[cpp]": {
        "files.encoding": "gb2312"
    },
    "[c]": {
        "files.encoding": "gb2312"
    },
    "[h]": {
        "files.encoding": "gb2312"
    },
    "[hpp]": {
        "files.encoding": "gb2312"
    },

    // 文件关联
    "files.associations": {
        "*.json": "jsonc",
        "*.h": "cpp",
        "*.cpp": "cpp",
        "*.hpp": "cpp",
        "*.tcc": "cpp",
        "deque": "cpp",
        "string": "cpp",
        "unordered_map": "cpp",
        "vector": "cpp",
        "typeinfo": "cpp",
        "array": "cpp",
        "cctype": "cpp",
        "clocale": "cpp",
        "cmath": "cpp",
        "cstdarg": "cpp",
        "cstdint": "cpp",
        "cstdio": "cpp",
        "cstdlib": "cpp",
        "cwchar": "cpp",
        "cwctype": "cpp",
        "exception": "cpp",
        "fstream": "cpp",
        "functional": "cpp",
        "initializer_list": "cpp",
        "iosfwd": "cpp",
        "istream": "cpp",
        "limits": "cpp",
        "new": "cpp",
        "ostream": "cpp",
        "numeric": "cpp",
        "sstream": "cpp",
        "stdexcept": "cpp",
        "streambuf": "cpp",
        "tuple": "cpp",
        "type_traits": "cpp",
        "utility": "cpp"
    },

    // 其他有用的设置
    "files.eol": "\r\n",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true
}
